# ─────────────────────────────────────────────────────────────────────────────
# Get your FREE Groq key at: https://console.groq.com/keys
# Sign up with Google (free, no credit card needed)
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# Required for AI interview functionality
GROQ_API_KEY=your-groq-key-here

# Required for Supabase database (optional for demo, but recommended for production)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Required for email report functionality (optional)
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-specific-password

# Deployment configuration (for Vercel)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
